WAKEWORD_MODELS=hey_jarvis
WAKEWORD_THRESHOLD=0.5

SILENCE_RMS=500
END_SILENCE_MS=800
MAX_COMMAND_MS=12000
MIN_SPEECH_MS=300

WHISPER_MODEL=models/faster-whisper-tiny.en
WHISPER_COMPUTE=int8

OLLAMA_BASE_URL=https://ollama.com/v1
OLLAMA_API_KEY=your_key_here
OLLAMA_MODEL=gpt-oss:20b-cloud

PIPER_MODEL=voices/en_US-lessac-medium.onnx
PIPER_CONFIG=voices/en_US-lessac-medium.onnx.json

SYSTEM_PROMPT=You are a helpful voice assistant. Answer in one or two short spoken sentences.
